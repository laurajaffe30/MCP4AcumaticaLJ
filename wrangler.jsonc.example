{
	"name": "acumatica-mcp-server",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-01",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	// Acumatica instance configuration
	// Set ACUMATICA_URL, ACUMATICA_COMPANY, and secrets via:
	//   npx wrangler secret put <NAME>
	// Or define in .dev.vars for local development
	"vars": {
		"ACUMATICA_ENDPOINT_VERSION": "25.200.001"
	},
	// KV namespace — create with:
	//   npx wrangler kv namespace create TOKEN_STORE
	// Then replace the ID below
	"kv_namespaces": [
		{
			"binding": "TOKEN_STORE",
			"id": "<your-token-store-kv-id>"
		}
	],

	// Keep workers.dev subdomain as fallback
	"workers_dev": true,

	// Custom domain (requires hallboys.com zone in your Cloudflare account)
	// Remove or comment out if using only the *.workers.dev subdomain
	"routes": [
		{
			"pattern": "acumatica-mcp.hallboys.com/*",
			"zone_name": "hallboys.com"
		}
	],

	// Durable Object for McpAgent (agents SDK)
	"durable_objects": {
		"bindings": [
			{
				"name": "MCP_OBJECT",
				"class_name": "AcumaticaMcpServer"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["AcumaticaMcpServer"]
		}
	]
}
